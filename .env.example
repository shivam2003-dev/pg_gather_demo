# PostgreSQL connection settings
POSTGRES_USER=pgadmin
POSTGRES_PASSWORD=pgadmin123
POSTGRES_DB=labdb

# PostgreSQL port exposed on the host
POSTGRES_PORT=5432

# Container name (used by docker exec and psql scripts)
PG_CONTAINER=pg_gather_db

# pg_gather report output directory (relative to project root)
REPORTS_DIR=./reports

# Postgres data directory (named volume)
PG_DATA_VOLUME=pg_gather_data

# Replica port (lab5 only — replica is off by default)
REPLICA_PORT=5433
